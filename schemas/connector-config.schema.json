{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sst/connector-config.schema.json",
  "title": "SBOM Security Toolkit Connector Configuration",
  "type": "object",
  "required": ["version", "connectors"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "connectors": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {"enum": ["snyk", "dependency-track", "defectdojo", "github", "webhook"]},
          "enabled": {"type": "boolean"},
          "mode": {"enum": ["read-only", "dry-run", "write"]},
          "base_url": {"type": "string"},
          "token_env": {"type": "string"},
          "project": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
