# SBOM Security Toolkit self-hosted cloud mode example.
# Copy to .env and edit before running docker/docker-compose.cloud.yml.
SST_BIND_ADDR=127.0.0.1
SST_STORAGE_BACKEND=s3
SST_OBJECT_BUCKET=sbom-security-toolkit
SST_OBJECT_PREFIX=sst/
AWS_REGION=us-east-1
POSTGRES_PASSWORD=change-me
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-change-me
SST_AUTH_ENABLED=false
SST_ADMIN_USER=admin
SST_ADMIN_PASSWORD=change-me
